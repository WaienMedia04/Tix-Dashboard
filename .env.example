# Connection string de Neon (Settings → Connection Details). Usa el host "-pooler" para la app.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Puerto donde escucha la API. Railway lo asigna automaticamente via $PORT.
PORT=3000

# Origenes permitidos para CORS, separados por coma. Debe incluir la URL exacta del dashboard en produccion.
CORS_ORIGIN="http://localhost:3001"

# Token para proteger GET /empresas (listado interno de clientes). Genera un valor largo y aleatorio.
ADMIN_TOKEN="cambia-este-valor-por-uno-aleatorio-largo"
