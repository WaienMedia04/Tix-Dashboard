generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  CEO
  RRHH
  MANAGER
  TALENTO
}

enum TipoNovedad {
  LOGRO
  BUENA_ACCION
  AUSENCIA
  ERROR
  SITUACION
}

enum TipoAusencia {
  PERMISO
  LICENCIA_MEDICA
  VACACIONES
}

model Empresa {
  id           String    @id @default(cuid())
  nombre       String
  slug         String    @unique
  plan         String
  codigoAcceso String
  botToken     String?   @unique
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  talentos     Talento[]
  worklogs     Worklog[]
  usuarios     Usuario[]
  novedades    Novedad[]
  ausencias    Ausencia[]
}

model Talento {
  id               String    @id @default(cuid())
  empresaId        String
  nombreCompleto   String
  apellido         String?
  rol              String
  departamento     String?
  estado           String
  cedula           String?
  correo           String?
  telefono         String?
  fechaIngreso     DateTime?
  fechaNacimiento  DateTime?
  direccion        String?
  notas            String?
  fotoUrl          String?
  cvUrl            String?
  cvDatosExtraidos Json?
  managerUsuarioId String?
  empresa          Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  manager          Usuario?  @relation("ManagerEquipo", fields: [managerUsuarioId], references: [id])
  usuario          Usuario?  @relation("UsuarioTalento")
  worklogs         Worklog[]
  novedades        Novedad[]
  ausencias        Ausencia[]

  @@index([empresaId])
  @@index([empresaId, managerUsuarioId])
}

model Usuario {
  id                  String    @id @default(cuid())
  empresaId           String
  email               String    @unique
  passwordHash        String
  nombre              String
  rol                 Rol
  talentoId           String?   @unique
  passwordDebeCambiar Boolean   @default(false)
  activo              Boolean   @default(true)
  ultimoLoginAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresa            Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento            Talento?  @relation("UsuarioTalento", fields: [talentoId], references: [id])
  equipoGestionado   Talento[] @relation("ManagerEquipo")
  sesiones           Sesion[]
  novedadesCreadas   Novedad[]
  ausenciasCreadas   Ausencia[]

  @@index([empresaId])
  @@index([empresaId, rol])
}

model Sesion {
  id        String    @id @default(cuid())
  usuarioId String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  userAgent String?
  revokedAt DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model Worklog {
  id                    String   @id @default(cuid())
  empresaId             String
  talentoId             String
  fecha                 DateTime
  tareasPlanificadas    String?
  horaCheckin           String?
  checkinEnviado        Boolean  @default(false)
  cumplimientoTareas    Int?
  actividadesRealizadas String?
  queSeEjecuto          String?
  detallesRelevantes    String?
  informeAvances        String?
  objetivoDia           String?
  estadoEnvio           String
  horaEnvio             String?
  dia                   String?
  semana                Int?
  capacitacion          String?
  puntajeIA             Int?
  calificacionCeo       String?
  notasTix              String?
  createdAt             DateTime @default(now())
  empresa               Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento               Talento  @relation(fields: [talentoId], references: [id], onDelete: Cascade)

  @@unique([talentoId, fecha])
  @@index([empresaId])
  @@index([empresaId, fecha])
}

model Novedad {
  id                 String      @id @default(cuid())
  empresaId          String
  talentoId          String
  tipo               TipoNovedad
  fecha              DateTime
  descripcion        String
  creadoPorUsuarioId String
  createdAt          DateTime    @default(now())

  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento   Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
}

model Ausencia {
  id                 String       @id @default(cuid())
  empresaId          String
  talentoId          String
  tipo               TipoAusencia
  fechaInicio        DateTime
  fechaFin           DateTime
  motivo             String?
  creadoPorUsuarioId String
  createdAt          DateTime     @default(now())

  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento   Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
}
