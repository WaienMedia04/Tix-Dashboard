generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id           String    @id @default(cuid())
  nombre       String
  slug         String    @unique
  plan         String
  codigoAcceso String
  botToken     String?   @unique
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  talentos     Talento[]
  worklogs     Worklog[]
}

model Talento {
  id              String    @id @default(cuid())
  empresaId       String
  nombreCompleto  String
  rol             String
  estado          String
  cedula          String?
  correo          String?
  telefono        String?
  fechaIngreso    DateTime?
  fechaNacimiento DateTime?
  direccion       String?
  notas           String?
  empresa         Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  worklogs        Worklog[]

  @@index([empresaId])
}

model Worklog {
  id                    String   @id @default(cuid())
  empresaId             String
  talentoId             String
  fecha                 DateTime
  actividadesRealizadas String?
  queSeEjecuto          String?
  detallesRelevantes    String?
  informeAvances        String?
  objetivoDia           String?
  estadoEnvio           String
  horaEnvio             String?
  dia                   String?
  semana                Int?
  capacitacion          String?
  puntajeIA             Int?
  calificacionCeo       String?
  notasTix              String?
  createdAt             DateTime @default(now())
  empresa               Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento               Talento  @relation(fields: [talentoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, fecha])
}
