generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  CEO
  RRHH
  MANAGER
  TALENTO
}

enum TipoNovedad {
  LOGRO
  BUENA_ACCION
  AUSENCIA
  ERROR
  SITUACION
}

enum TipoAusencia {
  PERMISO
  LICENCIA_MEDICA
  VACACIONES
}

enum TipoEstampaForma {
  REDONDEADO
  CIRCULAR
  CUADRADO
  DIAMANTE
  LIBRE
}

enum TipoNotificacion {
  ESTAMPA_RECIBIDA
  CUMPLEANOS
  AUSENCIA_REGISTRADA
  NOVEDAD_PUBLICADA
  CV_LISTO_PARA_REVISAR
  NOTA_RECIBIDA
}

model Empresa {
  id                String               @id @default(cuid())
  nombre            String
  slug              String               @unique
  plan              String
  codigoAcceso      String
  botToken          String?              @unique
  logoUrl           String?
  activo            Boolean              @default(true)
  createdAt         DateTime             @default(now())
  talentos          Talento[]
  worklogs          Worklog[]
  usuarios          Usuario[]
  novedades         Novedad[]
  ausencias         Ausencia[]
  perfilesMural     TalentoPerfilMural[]
  notasMural        MuralNotaAdhesiva[]
  estampasDefinidas EstampaDefinicion[]
  estampasOtorgadas EstampaOtorgada[]
  notificaciones    Notificacion[]
  departamentos     DepartamentoDefinicion[]
  solicitudesSoporte SolicitudSoporte[]
  chatConversaciones ChatConversacion[]
  pizarraPosts       PizarraPost[]
  pizarraEncuestas   PizarraEncuesta[]
  pizarraReconocimientos PizarraReconocimiento[]
  pizarraTriviaRespuestas PizarraTriviaRespuesta[]
}

/**
 * Catálogo de departamentos que el equipo de Talentix (panel admin) define
 * por empresa — CEO/RRHH eligen de esta lista al asignar el departamento de
 * un talento o de un Gerente (Usuario.departamentoGestionado), en vez de
 * escribirlo libremente, para que ambos lados coincidan siempre exacto.
 */
model DepartamentoDefinicion {
  id        String   @id @default(cuid())
  empresaId String
  nombre    String
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nombre])
  @@index([empresaId])
}

model Talento {
  id                String              @id @default(cuid())
  empresaId         String
  nombreCompleto    String
  apellido          String?
  rol               String
  departamento      String?
  estado            String
  cedula            String?
  correo            String?
  telefono          String?
  fechaIngreso      DateTime?
  fechaNacimiento   DateTime?
  direccion         String?
  notas             String?
  fotoUrl           String?
  carnetFotoUrl     String?
  cvUrl             String?
  cvDatosExtraidos  Json?
  managerUsuarioId  String?
  empresa           Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  manager           Usuario?            @relation("ManagerEquipo", fields: [managerUsuarioId], references: [id])
  usuario           Usuario?            @relation("UsuarioTalento")
  worklogs          Worklog[]
  novedades         Novedad[]
  ausencias         Ausencia[]
  perfilMural       TalentoPerfilMural?
  notasMural        MuralNotaAdhesiva[]
  estampasRecibidas EstampaOtorgada[]
  notificaciones    Notificacion[]
  pizarraReconocimientos PizarraReconocimiento[]

  @@index([empresaId])
  @@index([empresaId, managerUsuarioId])
}

model Usuario {
  id                  String    @id @default(cuid())
  empresaId           String
  email               String    @unique
  supabaseUserId      String    @unique
  passwordEstablecida Boolean   @default(false)
  nombre              String
  rol                 Rol
  talentoId           String?   @unique
  /// Solo aplica a rol MANAGER: nombre del departamento que gestiona (mismo
  /// texto libre que Talento.departamento) — talentoScopeWhere() lo usa para
  /// que un MANAGER vea en dashboard/rankings/reportes/KPIs a los talentos
  /// activos cuyo `departamento` coincida exactamente con este valor.
  departamentoGestionado String?
  activo              Boolean   @default(true)
  ultimoLoginAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresa              Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento              Talento?              @relation("UsuarioTalento", fields: [talentoId], references: [id])
  equipoGestionado     Talento[]             @relation("ManagerEquipo")
  novedadesCreadas     Novedad[]
  ausenciasCreadas     Ausencia[]
  estampasCreadas      EstampaDefinicion[]
  estampasOtorgadas    EstampaOtorgada[]
  notificacionesLeidas NotificacionLectura[]
  notasMuralEnviadas   MuralNotaAdhesiva[]
  solicitudesSoporte   SolicitudSoporte[]
  chatConversacionesCreadas ChatConversacion[]  @relation("ChatConversacionesCreadas")
  chatParticipaciones  ChatParticipante[]
  chatMensajes         ChatMensaje[]
  pizarraPostsCreados       PizarraPost[]       @relation("PizarraPostsCreados")
  pizarraReacciones         PizarraReaccion[]
  pizarraComentariosCreados PizarraComentario[] @relation("PizarraComentariosCreados")
  pizarraMenciones          PizarraMencion[]
  pizarraEncuestasCreadas       PizarraEncuesta[]         @relation("PizarraEncuestasCreadas")
  pizarraEncuestaVotos         PizarraEncuestaVoto[]
  pizarraReconocimientosCreados PizarraReconocimiento[]   @relation("PizarraReconocimientosCreados")
  pizarraTriviaRespuestas      PizarraTriviaRespuesta[]

  @@index([empresaId])
  @@index([empresaId, rol])
}

enum TipoSoporte {
  AVERIA
  SUGERENCIA
}

/// Solicitudes de soporte que CEO/RRHH/Gerente envían desde el Dock del
/// panel — las revisa el equipo de Talentix (IAGIL) desde el panel admin,
/// no algo que la propia empresa consulte de vuelta.
model SolicitudSoporte {
  id        String      @id @default(cuid())
  empresaId String
  usuarioId String
  tipo      TipoSoporte
  mensaje   String
  leida     Boolean     @default(false)
  createdAt DateTime    @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([leida])
}

model Worklog {
  id                    String   @id @default(cuid())
  empresaId             String
  talentoId             String
  fecha                 DateTime
  tareasPlanificadas    String?
  horaCheckin           String?
  checkinEnviado        Boolean  @default(false)
  cumplimientoTareas    Int?
  actividadesRealizadas String?
  queSeEjecuto          String?
  detallesRelevantes    String?
  informeAvances        String?
  objetivoDia           String?
  estadoEnvio           String
  horaEnvio             String?
  dia                   String?
  semana                Int?
  capacitacion          String?
  puntajeIA             Int?
  calificacionCeo       String?
  notasTix              String?
  createdAt             DateTime @default(now())
  empresa               Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento               Talento  @relation(fields: [talentoId], references: [id], onDelete: Cascade)

  @@unique([talentoId, fecha])
  @@index([empresaId])
  @@index([empresaId, fecha])
}

model Novedad {
  id                 String      @id @default(cuid())
  empresaId          String
  talentoId          String
  tipo               TipoNovedad
  fecha              DateTime
  descripcion        String
  creadoPorUsuarioId String
  createdAt          DateTime    @default(now())

  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento   Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
}

model Ausencia {
  id                 String       @id @default(cuid())
  empresaId          String
  talentoId          String
  tipo               TipoAusencia
  fechaInicio        DateTime
  fechaFin           DateTime
  motivo             String?
  creadoPorUsuarioId String
  createdAt          DateTime     @default(now())

  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento   Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
}

model TalentoPerfilMural {
  id              String   @id @default(cuid())
  empresaId       String
  talentoId       String   @unique
  apodo           String?
  meGusta         String?
  noMeGusta       String?
  cancionFavorita String?
  superpoder      String?
  /// Hasta 5 palabras que describen la personalidad del talento — se
  /// muestran en efecto "máquina de escribir" arriba de su mural y en el
  /// panel "Sobre mí".
  personalidades  String[] @default([])
  /// Estado actual del talento (ej. "Trabajando", "En reunión", o texto
  /// libre) — se muestra como una píldora animada arriba del nombre.
  estado          String?
  fondoId         String   @default("corcho")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}

model MuralNotaAdhesiva {
  id                  String   @id @default(cuid())
  empresaId           String
  talentoId           String
  texto               String
  color               String   @default("amarillo")
  posX                Float    @default(50)
  posY                Float    @default(50)
  rotacion            Float    @default(0)
  zIndex              Int      @default(0)
  escala              Float    @default(1)
  /// Si no es null, la nota la escribió otro compañero (no el dueño del mural) — se muestra "De: {nombre}".
  enviadaPorUsuarioId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento    Talento  @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  enviadaPor Usuario? @relation(fields: [enviadaPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
}

model EstampaDefinicion {
  id                 String           @id @default(cuid())
  empresaId          String
  nombre             String
  imagenUrl          String
  forma              TipoEstampaForma
  activo             Boolean          @default(true)
  creadoPorUsuarioId String
  createdAt          DateTime         @default(now())

  empresa   Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  creadoPor Usuario           @relation(fields: [creadoPorUsuarioId], references: [id])
  grants    EstampaOtorgada[]

  @@index([empresaId])
}

model EstampaOtorgada {
  id                   String   @id @default(cuid())
  empresaId            String
  talentoId            String
  estampaDefinicionId  String
  otorgadoPorUsuarioId String
  mensaje              String?
  posX                 Float    @default(50)
  posY                 Float    @default(50)
  zIndex               Int      @default(0)
  enMural              Boolean  @default(true)
  createdAt            DateTime @default(now())

  empresa           Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento           Talento           @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  estampaDefinicion EstampaDefinicion @relation(fields: [estampaDefinicionId], references: [id], onDelete: Cascade)
  otorgadoPor       Usuario           @relation(fields: [otorgadoPorUsuarioId], references: [id])

  @@index([empresaId])
  @@index([empresaId, talentoId])
  @@index([estampaDefinicionId])
}

/**
 * Si `personal` es true, solo la ve el usuario asociado a `talentoId`.
 * Si es false, es un aviso general: lo ve todo el que tenga uno de los
 * roles en `rolesDestino` (vacío = todos los roles). `talentoId` en ese
 * caso es solo una referencia informativa (ej. de quién es el cumpleaños),
 * no restringe quién la ve.
 */
model Notificacion {
  id           String           @id @default(cuid())
  empresaId    String
  tipo         TipoNotificacion
  titulo       String
  mensaje      String
  personal     Boolean          @default(false)
  rolesDestino Rol[]
  talentoId    String?
  enlace       String?
  createdAt    DateTime         @default(now())

  empresa  Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento  Talento?              @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  lecturas NotificacionLectura[]

  @@index([empresaId])
  @@index([empresaId, talentoId])
  @@index([empresaId, createdAt])
}

model NotificacionLectura {
  id             String   @id @default(cuid())
  notificacionId String
  usuarioId      String
  leidoAt        DateTime @default(now())

  notificacion Notificacion @relation(fields: [notificacionId], references: [id], onDelete: Cascade)
  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([notificacionId, usuarioId])
  @@index([usuarioId])
}

/**
 * Conversación de chat interno entre usuarios de una misma empresa. Si
 * `esGrupo` es false tiene exactamente 2 participantes (chat 1 a 1) y
 * `nombre` es null — el frontend muestra el nombre del otro participante.
 */
model ChatConversacion {
  id                 String    @id @default(cuid())
  empresaId          String
  esGrupo            Boolean   @default(false)
  nombre             String?
  creadoPorUsuarioId String?
  createdAt          DateTime  @default(now())

  empresa       Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  creadoPor     Usuario?           @relation("ChatConversacionesCreadas", fields: [creadoPorUsuarioId], references: [id])
  participantes ChatParticipante[]
  mensajes      ChatMensaje[]

  @@index([empresaId])
}

/**
 * `ultimaLecturaAt` es el puntero de "leído hasta aquí" de este usuario en
 * esta conversación — se actualiza al abrir/listar los mensajes. De ahí se
 * derivan tanto el contador de no leídos como el parpadeo de chismes
 * pendientes, sin necesitar una fila de lectura por mensaje.
 */
model ChatParticipante {
  id              String    @id @default(cuid())
  conversacionId  String
  usuarioId       String
  ultimaLecturaAt DateTime?
  createdAt       DateTime  @default(now())

  conversacion ChatConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  usuario      Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([conversacionId, usuarioId])
  @@index([usuarioId])
}

/// Si `esChisme` es true, el mensaje se muestra destacado en el hilo y hace
/// parpadear en rojo el botón flotante de chat de los demás participantes
/// hasta que lo leen.
model ChatMensaje {
  id             String   @id @default(cuid())
  conversacionId String
  autorUsuarioId String
  texto          String
  esChisme       Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversacion ChatConversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  autor        Usuario          @relation(fields: [autorUsuarioId], references: [id])

  @@index([conversacionId, createdAt])
}

/**
 * Pizarra compartida de la empresa: un muro social visible igual desde el
 * mural de cualquier talento (agradecimientos, avisos, menciones). El texto
 * puede incluir menciones codificadas como `@[Nombre](usuarioId)` — el
 * frontend las resuelve al renderizar y el backend las usa para crear las
 * filas de PizarraMencion.
 */
model PizarraPost {
  id             String   @id @default(cuid())
  empresaId      String
  autorUsuarioId String
  texto          String
  createdAt      DateTime @default(now())

  empresa     Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  autor       Usuario             @relation("PizarraPostsCreados", fields: [autorUsuarioId], references: [id])
  reacciones  PizarraReaccion[]
  comentarios PizarraComentario[]
  menciones   PizarraMencion[]

  @@index([empresaId, createdAt])
}

/// Un usuario puede reaccionar a un mismo post con varios emojis distintos, pero no repetir el mismo emoji dos veces.
model PizarraReaccion {
  id        String   @id @default(cuid())
  postId    String
  usuarioId String
  emoji     String
  createdAt DateTime @default(now())

  post    PizarraPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuario Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([postId, usuarioId, emoji])
  @@index([postId])
}

model PizarraComentario {
  id             String   @id @default(cuid())
  postId         String
  autorUsuarioId String
  texto          String
  createdAt      DateTime @default(now())

  post  PizarraPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  autor Usuario     @relation("PizarraComentariosCreados", fields: [autorUsuarioId], references: [id])

  @@index([postId, createdAt])
}

model PizarraMencion {
  id        String @id @default(cuid())
  postId    String
  usuarioId String

  post    PizarraPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuario Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([postId, usuarioId])
  @@index([usuarioId])
}

/// Encuesta que publica CEO/RRHH en la pizarra — solo se muestra la más
/// reciente como "activa"; las anteriores quedan en el historial.
model PizarraEncuesta {
  id                 String   @id @default(cuid())
  empresaId          String
  creadoPorUsuarioId String
  pregunta           String
  opciones           String[]
  createdAt          DateTime @default(now())

  empresa   Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  creadoPor Usuario               @relation("PizarraEncuestasCreadas", fields: [creadoPorUsuarioId], references: [id])
  votos     PizarraEncuestaVoto[]

  @@index([empresaId, createdAt])
}

/// Un voto por usuario por encuesta — votar de nuevo reemplaza el voto anterior (upsert).
model PizarraEncuestaVoto {
  id          String   @id @default(cuid())
  encuestaId  String
  usuarioId   String
  opcionIndex Int
  createdAt   DateTime @default(now())

  encuesta PizarraEncuesta @relation(fields: [encuestaId], references: [id], onDelete: Cascade)
  usuario  Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([encuestaId, usuarioId])
  @@index([encuestaId])
}

/// "Empleado del mes/semana" o "Proyecto destacado" que fija CEO/RRHH en la
/// pizarra — solo el más reciente con `activo` true se muestra.
model PizarraReconocimiento {
  id                 String   @id @default(cuid())
  empresaId          String
  talentoId          String
  titulo             String
  descripcion        String?
  creadoPorUsuarioId String
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())

  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  talento   Talento @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation("PizarraReconocimientosCreados", fields: [creadoPorUsuarioId], references: [id])

  @@index([empresaId, activo])
}

/// Respuesta a la trivia del día — la pregunta en sí vive en código (banco
/// fijo, rotación determinística por fecha), acá solo se guarda quién
/// acertó cada día, para el ranking.
model PizarraTriviaRespuesta {
  id        String   @id @default(cuid())
  empresaId String
  usuarioId String
  fecha     String
  correcta  Boolean
  createdAt DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([empresaId, usuarioId, fecha])
  @@index([empresaId, fecha])
}
